# =============================================================================
# mcMMO — Singleplayer Fabric mod (.gitignore)
# =============================================================================

# ── Secrets & local config ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore
.mcp.json

# ── Agent / editor local config ──────────────────────────────────────────────
.claude/
CLAUDE.md
.vscode/
!.vscode/extensions.json
.idea/
*.iml
*.ipr
*.iws
out/
.settings/
.project
.classpath
.nb-gradle/
nbproject/

# ── Gradle (primary build after Fabric migration) ────────────────────────────
.gradle/
build/
**/build/
gradle-app.setting
.gradletasknamecache

# ── Fabric Loom ──────────────────────────────────────────────────────────────
# Loom's decompiled/remapped caches, generated run dir and sources
.fabric/
run/
!run/README.md
remappedSrc/

# ── Maven (legacy build; remove once pom.xml is dropped) ──────────────────────
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
.flattened-pom.xml

# ── Java / JVM ───────────────────────────────────────────────────────────────
*.class
*.log
*.jar
# Gradle wrapper jar must be committed so CI can run ./gradlew
!gradle/wrapper/gradle-wrapper.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# ── OS generated ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/
